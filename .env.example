# Runie Environment Variables
# Copy this file to .env in your project root or ~/.runie/.env

# ── Anthropic ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── DeepSeek ───────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...

# ── Grok (xAI) ─────────────────────────────────────────────────────────────────
XAI_API_KEY=xai-...

# ── MiniMax ────────────────────────────────────────────────────────────────────
MINIMAX_API_KEY=...

# ── Ollama (local) ─────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── LM Studio ──────────────────────────────────────────────────────────────────
# LMSTUDIO_BASE_URL=http://localhost:1234

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "description": "Canonical config type for `~/.runie/config.toml`.",
  "type": "object",
  "properties": {
    "hooks": {
      "description": "Hook commands registered by event name.",
      "$ref": "#/$defs/HooksConfig",
      "default": {
        "commands": {}
      }
    },
    "keybindings": {
      "description": "User-defined keybindings that override defaults.\nParsed from `[keybindings]` table in `config.toml`.",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "model": {
      "description": "Legacy model field (use `[models].default` instead).",
      "type": [
        "string",
        "null"
      ]
    },
    "model_providers": {
      "description": "Provider configurations.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ModelProvider"
      },
      "default": {}
    },
    "models": {
      "description": "Model configurations.",
      "$ref": "#/$defs/ModelsSection",
      "default": {
        "default": null,
        "scoped": null
      }
    },
    "prompts": {
      "description": "Prompt templates.",
      "$ref": "#/$defs/PromptsSection",
      "default": {
        "custom": null,
        "default": null
      }
    },
    "provider": {
      "description": "Default provider name.",
      "type": [
        "string",
        "null"
      ]
    },
    "telemetry": {
      "description": "Telemetry settings.",
      "$ref": "#/$defs/TelemetrySection",
      "default": {
        "enabled": true
      }
    },
    "theme": {
      "description": "Theme name.",
      "type": [
        "string",
        "null"
      ]
    },
    "thinking_level": {
      "description": "Thinking level for reasoning-intensive tasks.",
      "$ref": "#/$defs/ThinkingLevel",
      "default": "Off"
    },
    "truncation": {
      "description": "Truncation settings.",
      "$ref": "#/$defs/TruncationSection",
      "default": {
        "max_bytes": 51200,
        "max_lines": 2000
      }
    },
    "ui": {
      "description": "UI settings.",
      "$ref": "#/$defs/UiSection",
      "default": {
        "vim_mode": true
      }
    }
  },
  "$defs": {
    "HooksConfig": {
      "description": "Hook configuration.",
      "type": "object",
      "properties": {
        "commands": {
          "description": "Map of hook event name to list of shell commands to run.",
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default": {}
        }
      }
    },
    "ModelProvider": {
      "description": "A provider's configuration entry.",
      "type": "object",
      "properties": {
        "api_key": {
          "type": "string"
        },
        "base_url": {
          "type": "string"
        },
        "models": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "type": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "base_url",
        "api_key"
      ]
    },
    "ModelsSection": {
      "description": "Models configuration section.",
      "type": "object",
      "properties": {
        "default": {
          "description": "The default model to use when no model is specified.",
          "type": [
            "string",
            "null"
          ]
        },
        "scoped": {
          "description": "Scoped models list (for model selector UI).",
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PromptsSection": {
      "description": "Prompts configuration section.",
      "type": "object",
      "properties": {
        "custom": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "default": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "TelemetrySection": {
      "description": "Telemetry configuration section.",
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "ThinkingLevel": {
      "description": "Thinking level for reasoning-intensive tasks.",
      "type": "string",
      "enum": [
        "Off",
        "Low",
        "Medium",
        "High"
      ]
    },
    "TruncationSection": {
      "description": "Truncation limits for tool output.",
      "type": "object",
      "properties": {
        "max_bytes": {
          "type": "integer",
          "format": "uint",
          "default": 51200,
          "minimum": 0
        },
        "max_lines": {
          "type": "integer",
          "format": "uint",
          "default": 2000,
          "minimum": 0
        }
      }
    },
    "UiSection": {
      "description": "UI configuration section.",
      "type": "object",
      "properties": {
        "vim_mode": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
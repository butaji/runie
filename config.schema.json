{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "description": "Canonical config type for `~/.runie/config.toml`.",
  "type": "object",
  "properties": {
    "fff": {
      "description": "FFF full-text search settings.",
      "$ref": "#/$defs/FffSection",
      "default": {
        "default_limit": 50,
        "max_file_size_bytes": 2097152,
        "scan_timeout_secs": 30
      }
    },
    "goal": {
      "description": "Goal mode configuration.",
      "$ref": "#/$defs/GoalSection",
      "default": {
        "auto_verify": true,
        "enabled": true,
        "max_checkpoints": 20,
        "max_rounds": 10,
        "show_pane": true,
        "token_budget": null
      }
    },
    "hooks": {
      "description": "Hook commands registered by event name.",
      "$ref": "#/$defs/HooksConfig",
      "default": {
        "commands": {}
      }
    },
    "http": {
      "description": "HTTP timeouts for provider network calls.",
      "$ref": "#/$defs/HttpSection",
      "default": {
        "connect_timeout_secs": 10,
        "request_timeout_secs": 120
      }
    },
    "keybindings": {
      "description": "User-defined keybindings that override defaults.",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "mcp": {
      "description": "MCP server configurations.",
      "$ref": "#/$defs/McpSection",
      "default": {
        "servers": {}
      }
    },
    "mode": {
      "description": "Agent orchestration pattern settings.",
      "$ref": "#/$defs/ModeSection",
      "default": {
        "active": "single",
        "circuit_breaker": 3,
        "max_retries": 2,
        "max_rounds": 5,
        "timeout_ms": 120000,
        "workers": 3
      }
    },
    "model": {
      "description": "Legacy model field (use `[models].default` instead).",
      "type": [
        "string",
        "null"
      ]
    },
    "model_providers": {
      "description": "Provider configurations.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ModelProvider"
      },
      "default": {}
    },
    "models": {
      "description": "Model configurations.",
      "$ref": "#/$defs/ModelsSection",
      "default": {
        "context_window_fallback": [],
        "default": null,
        "routing_strategy": "simple-shuffle",
        "scoped": null,
        "thinking": {}
      }
    },
    "permissions": {
      "description": "Permission settings.",
      "$ref": "#/$defs/PermissionsSection",
      "default": {
        "mode": "default",
        "rules": []
      }
    },
    "prompts": {
      "description": "Prompt templates.",
      "$ref": "#/$defs/PromptsSection",
      "default": {
        "custom": null,
        "default": null
      }
    },
    "provider": {
      "description": "Default provider name.",
      "type": [
        "string",
        "null"
      ]
    },
    "retry": {
      "description": "Retry policy for transient provider errors.",
      "$ref": "#/$defs/RetrySection",
      "default": {
        "initial_delay_ms": 100,
        "max_attempts": 5,
        "max_delay_ms": 30000,
        "multiplier": 2.0
      }
    },
    "sandbox": {
      "description": "OS-level sandbox settings for bash tool execution.",
      "$ref": "#/$defs/SandboxSection",
      "default": {
        "enabled": false
      }
    },
    "skills": {
      "description": "Skills configuration.",
      "$ref": "#/$defs/SkillsConfig",
      "default": {
        "disabled": [],
        "ignore": [],
        "paths": []
      }
    },
    "telemetry": {
      "description": "Telemetry settings.",
      "$ref": "#/$defs/TelemetrySection",
      "default": {
        "enabled": true
      }
    },
    "theme": {
      "description": "Theme name.",
      "type": [
        "string",
        "null"
      ]
    },
    "thinking_level": {
      "description": "Thinking level for reasoning-intensive tasks.",
      "$ref": "#/$defs/ThinkingLevel",
      "default": "Off"
    },
    "tool_cache": {
      "description": "Tool result cache settings.",
      "$ref": "#/$defs/ToolCacheSection",
      "default": {
        "ttl_secs": 300
      }
    },
    "truncation": {
      "description": "Truncation settings.",
      "$ref": "#/$defs/TruncationSection",
      "default": {
        "max_bytes": 51200,
        "max_lines": 2000
      }
    },
    "ui": {
      "description": "UI settings.",
      "$ref": "#/$defs/UiSection",
      "default": {
        "history_max_entries": 1000,
        "page_size": 5,
        "vim_mode": true
      }
    }
  },
  "$defs": {
    "ConfigScope": {
      "description": "Config scope for operations that can target global or project config.",
      "oneOf": [
        {
          "description": "Global config (~/.runie/config.toml)",
          "type": "string",
          "const": "global"
        },
        {
          "description": "Project config (.runie/config.toml)",
          "type": "string",
          "const": "project"
        }
      ]
    },
    "FffSection": {
      "description": "FFF full-text search configuration.",
      "type": "object",
      "properties": {
        "default_limit": {
          "description": "Default maximum number of results to return (default: 50).",
          "type": "integer",
          "format": "uint",
          "default": 50,
          "minimum": 0
        },
        "max_file_size_bytes": {
          "description": "Maximum file size in bytes to index (default: 2 MiB).",
          "type": "integer",
          "format": "uint",
          "default": 2097152,
          "minimum": 0
        },
        "scan_timeout_secs": {
          "description": "Scan timeout in seconds (default: 30).",
          "type": "integer",
          "format": "uint64",
          "default": 30,
          "minimum": 0
        }
      }
    },
    "GoalSection": {
      "description": "Goal mode configuration section.",
      "type": "object",
      "properties": {
        "auto_verify": {
          "description": "Auto-verify after each task completion.",
          "type": "boolean",
          "default": true
        },
        "enabled": {
          "description": "Enable goal mode.",
          "type": "boolean",
          "default": true
        },
        "max_checkpoints": {
          "description": "Max checkpoints to track.",
          "type": "integer",
          "format": "uint",
          "default": 20,
          "minimum": 0
        },
        "max_rounds": {
          "description": "Max verification rounds before pausing.",
          "type": "integer",
          "format": "uint",
          "default": 10,
          "minimum": 0
        },
        "show_pane": {
          "description": "Show goal pane in UI.",
          "type": "boolean",
          "default": true
        },
        "token_budget": {
          "description": "Token budget for goal execution (None = unlimited).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": null,
          "minimum": 0
        }
      }
    },
    "HooksConfig": {
      "description": "Hook configuration.",
      "type": "object",
      "properties": {
        "commands": {
          "description": "Map of hook event name to list of shell commands to run.",
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default": {}
        }
      }
    },
    "HttpSection": {
      "description": "HTTP and retry configuration for provider network calls.",
      "type": "object",
      "properties": {
        "connect_timeout_secs": {
          "description": "Connection timeout in seconds (default: 10).",
          "type": "integer",
          "format": "uint64",
          "default": 10,
          "minimum": 0
        },
        "request_timeout_secs": {
          "description": "Request timeout in seconds (default: 120).",
          "type": "integer",
          "format": "uint64",
          "default": 120,
          "minimum": 0
        }
      }
    },
    "McpSection": {
      "description": "MCP server configuration section.",
      "type": "object",
      "properties": {
        "servers": {
          "description": "Named MCP server configurations.",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/McpServer"
          },
          "default": {}
        }
      }
    },
    "McpServer": {
      "description": "An MCP server configuration entry.",
      "type": "object",
      "properties": {
        "command": {
          "description": "Command and arguments for stdio transport.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "headers": {
          "description": "HTTP headers for http/sse transports.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "scope": {
          "description": "Scope: global or project.",
          "$ref": "#/$defs/ConfigScope",
          "default": "global"
        },
        "transport": {
          "description": "Transport type: stdio, http, or sse.",
          "$ref": "#/$defs/McpTransport",
          "default": "stdio"
        },
        "url": {
          "description": "URL for http/sse transports.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "McpTransport": {
      "description": "Transport type for MCP server communication.",
      "oneOf": [
        {
          "description": "Stdio-based MCP server (default).",
          "type": "string",
          "const": "stdio"
        },
        {
          "description": "HTTP-based MCP server.",
          "type": "string",
          "const": "http"
        },
        {
          "description": "Server-Sent Events transport.",
          "type": "string",
          "const": "sse"
        },
        {
          "description": "WebSocket-based MCP server.",
          "type": "string",
          "const": "websocket"
        }
      ]
    },
    "ModeSection": {
      "description": "Agent orchestration pattern configuration (`[mode]` in config.toml).\n\nSee PATTERNS.md: `active` selects the orchestration pattern\n(`single` | `swarm` | `improve`); the remaining fields bound\nworker concurrency, iterations, per-task timeout, retries, and the\nconsecutive-failure circuit breaker.",
      "type": "object",
      "properties": {
        "active": {
          "description": "Active orchestration pattern: \"single\" | \"swarm\" | \"improve\".",
          "type": "string",
          "default": "single"
        },
        "circuit_breaker": {
          "description": "Consecutive failures before fail-fast.",
          "type": "integer",
          "format": "uint32",
          "default": 3,
          "minimum": 0
        },
        "lead_model": {
          "description": "Lead (coordinator) model for swarm/delegation patterns.\nFormat: \"provider/model\". Uses current model if None.",
          "type": [
            "string",
            "null"
          ]
        },
        "max_retries": {
          "description": "Retries per task on failure.",
          "type": "integer",
          "format": "uint32",
          "default": 2,
          "minimum": 0
        },
        "max_rounds": {
          "description": "Max iterations (improve, swarm).",
          "type": "integer",
          "format": "uint",
          "default": 5,
          "minimum": 0
        },
        "timeout_ms": {
          "description": "Per-task timeout in milliseconds.",
          "type": "integer",
          "format": "uint64",
          "default": 120000,
          "minimum": 0
        },
        "worker_model": {
          "description": "Worker (task-executor) model for swarm/delegation patterns.\nFormat: \"provider/model\". Uses current model if None.",
          "type": [
            "string",
            "null"
          ]
        },
        "workers": {
          "description": "Max parallel workers.",
          "type": "integer",
          "format": "uint",
          "default": 3,
          "minimum": 0
        }
      }
    },
    "ModelId": {
      "description": "A model identifier in `\"provider/model\"` form.",
      "type": "string"
    },
    "ModelProvider": {
      "description": "A provider's configuration entry.\nAPI keys are resolved from environment variables or OS keyring, not stored here.",
      "type": "object",
      "properties": {
        "base_url": {
          "type": "string"
        },
        "context_window_fallbacks": {
          "description": "Fallback model IDs to try when the primary model cannot handle a request\n(e.g., context window exceeded). Ordered by priority.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ModelId"
          }
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "models": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "type": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "base_url"
      ]
    },
    "ModelRoutingStrategy": {
      "description": "Strategy for routing between multiple model deployments.",
      "oneOf": [
        {
          "description": "Round-robin through available deployments.",
          "type": "string",
          "const": "simple-shuffle"
        },
        {
          "description": "Route to the lowest-latency deployment.",
          "type": "string",
          "const": "latency-based"
        },
        {
          "description": "Route to the cheapest deployment for the task.",
          "type": "string",
          "const": "cost-based"
        }
      ]
    },
    "ModelsSection": {
      "description": "Models configuration section.",
      "type": "object",
      "properties": {
        "context_window_fallback": {
          "description": "Fallback models to use when context window is exceeded.\nListed in order of preference (first available is used).",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "default": {
          "description": "The default model to use when no model is specified.",
          "type": [
            "string",
            "null"
          ]
        },
        "routing_strategy": {
          "description": "Routing strategy for multi-deployment providers.",
          "$ref": "#/$defs/ModelRoutingStrategy",
          "default": "simple-shuffle"
        },
        "scoped": {
          "description": "Scoped models list (for model selector UI).",
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "type": "string"
          }
        },
        "thinking": {
          "description": "Per-model thinking (reasoning) level overrides, keyed\n`\"provider/model\"`. Models without an entry inherit the global\n`thinking_level`.",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/ThinkingLevel"
          },
          "default": {}
        }
      }
    },
    "PermissionAction": {
      "description": "Permission action result — kept for API compatibility.",
      "type": "string",
      "enum": [
        "allow",
        "ask",
        "deny"
      ]
    },
    "PermissionMode": {
      "description": "Permission mode — stub. All modes now bypass.",
      "type": "string",
      "enum": [
        "default",
        "accept_edits",
        "auto",
        "dont_ask",
        "bypass_permissions",
        "plan"
      ]
    },
    "PermissionRule": {
      "description": "Permission rule — stub for config compatibility.",
      "type": "object",
      "properties": {
        "action": {
          "$ref": "#/$defs/PermissionAction"
        },
        "pattern": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool": {
          "type": "string"
        }
      },
      "required": [
        "action",
        "tool"
      ]
    },
    "PermissionsSection": {
      "description": "Permissions configuration section.",
      "type": "object",
      "properties": {
        "mode": {
          "description": "Permission mode: default, acceptEdits, auto, dontAsk, bypassPermissions, plan.",
          "$ref": "#/$defs/PermissionMode",
          "default": "default"
        },
        "rules": {
          "description": "Explicit permission rules.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/PermissionRule"
          }
        }
      }
    },
    "PromptsSection": {
      "description": "Prompts configuration section.",
      "type": "object",
      "properties": {
        "custom": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "default": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "RetrySection": {
      "description": "Retry configuration for transient provider errors.",
      "type": "object",
      "properties": {
        "initial_delay_ms": {
          "description": "Initial delay in milliseconds (default: 100).",
          "type": "integer",
          "format": "uint64",
          "default": 100,
          "minimum": 0
        },
        "max_attempts": {
          "description": "Maximum number of retry attempts (default: 5).",
          "type": "integer",
          "format": "uint32",
          "default": 5,
          "minimum": 0
        },
        "max_delay_ms": {
          "description": "Maximum delay in milliseconds (default: 30000).",
          "type": "integer",
          "format": "uint64",
          "default": 30000,
          "minimum": 0
        },
        "multiplier": {
          "description": "Exponential backoff multiplier (default: 2.0).",
          "type": "number",
          "format": "double",
          "default": 2.0
        }
      }
    },
    "SandboxSection": {
      "description": "Sandbox configuration for OS-level command sandboxing.",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Enable OS-level sandboxing for bash tool execution.\nWhen enabled, bash commands are wrapped in platform-specific sandbox.\nDefaults to false.",
          "type": "boolean",
          "default": false
        }
      }
    },
    "SkillsConfig": {
      "description": "Skills configuration for skill discovery and management.",
      "type": "object",
      "properties": {
        "disabled": {
          "description": "List of disabled skill names. Disabled skills are excluded from the\nsystem prompt and skill tool invocation but remain discoverable.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "ignore": {
          "description": "Path prefixes to exclude from skill discovery.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "paths": {
          "description": "Additional skill locations to load. Each entry is a `SKILL.md` file or\na directory walked recursively. Supports `~` expansion.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "TelemetrySection": {
      "description": "Telemetry configuration section.",
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "ThinkingLevel": {
      "description": "Thinking level for reasoning-intensive tasks.",
      "type": "string",
      "enum": [
        "Off",
        "Low",
        "Medium",
        "High"
      ]
    },
    "ToolCacheSection": {
      "description": "Tool result cache configuration.",
      "type": "object",
      "properties": {
        "ttl_secs": {
          "description": "TTL in seconds for cached tool results. Zero disables the cache.",
          "type": "integer",
          "format": "uint64",
          "default": 300,
          "minimum": 0
        }
      }
    },
    "TruncationSection": {
      "description": "Truncation limits for tool output.",
      "type": "object",
      "properties": {
        "max_bytes": {
          "type": "integer",
          "format": "uint",
          "default": 51200,
          "minimum": 0
        },
        "max_lines": {
          "type": "integer",
          "format": "uint",
          "default": 2000,
          "minimum": 0
        }
      }
    },
    "UiSection": {
      "description": "UI configuration section.",
      "type": "object",
      "properties": {
        "history_max_entries": {
          "description": "Maximum number of input history entries to retain.",
          "type": "integer",
          "format": "uint",
          "default": 1000,
          "minimum": 0
        },
        "page_size": {
          "description": "Number of items per page in list dialogs.",
          "type": "integer",
          "format": "uint",
          "default": 5,
          "minimum": 0
        },
        "vim_mode": {
          "description": "Enable vim-style navigation mode.",
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "description": "Canonical config type for `~/.runie/config.toml`.",
  "type": "object",
  "properties": {
    "hooks": {
      "description": "Hook commands registered by event name.",
      "$ref": "#/$defs/HooksConfig",
      "default": {
        "commands": {}
      }
    },
    "keybindings": {
      "description": "User-defined keybindings that override defaults.",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "mcp": {
      "description": "MCP server configurations.",
      "$ref": "#/$defs/McpSection",
      "default": {
        "servers": {}
      }
    },
    "model": {
      "description": "Legacy model field (use `[models].default` instead).",
      "type": [
        "string",
        "null"
      ]
    },
    "model_providers": {
      "description": "Provider configurations.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ModelProvider"
      },
      "default": {}
    },
    "models": {
      "description": "Model configurations.",
      "$ref": "#/$defs/ModelsSection",
      "default": {
        "default": null,
        "scoped": null
      }
    },
    "permissions": {
      "description": "Permission settings.",
      "$ref": "#/$defs/PermissionsSection",
      "default": {
        "mode": "default",
        "rules": []
      }
    },
    "prompts": {
      "description": "Prompt templates.",
      "$ref": "#/$defs/PromptsSection",
      "default": {
        "custom": null,
        "default": null
      }
    },
    "provider": {
      "description": "Default provider name.",
      "type": [
        "string",
        "null"
      ]
    },
    "telemetry": {
      "description": "Telemetry settings.",
      "$ref": "#/$defs/TelemetrySection",
      "default": {
        "enabled": true
      }
    },
    "theme": {
      "description": "Theme name.",
      "type": [
        "string",
        "null"
      ]
    },
    "thinking_level": {
      "description": "Thinking level for reasoning-intensive tasks.",
      "$ref": "#/$defs/ThinkingLevel",
      "default": "Off"
    },
    "truncation": {
      "description": "Truncation settings.",
      "$ref": "#/$defs/TruncationSection",
      "default": {
        "max_bytes": 51200,
        "max_lines": 2000
      }
    },
    "ui": {
      "description": "UI settings.",
      "$ref": "#/$defs/UiSection",
      "default": {
        "vim_mode": true
      }
    }
  },
  "$defs": {
    "ConfigScope": {
      "description": "Config scope for operations that can target global or project config.",
      "oneOf": [
        {
          "description": "Global config (~/.runie/config.toml)",
          "type": "string",
          "const": "global"
        },
        {
          "description": "Project config (.runie/config.toml)",
          "type": "string",
          "const": "project"
        }
      ]
    },
    "HooksConfig": {
      "description": "Hook configuration.",
      "type": "object",
      "properties": {
        "commands": {
          "description": "Map of hook event name to list of shell commands to run.",
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default": {}
        }
      }
    },
    "McpSection": {
      "description": "MCP server configuration section.",
      "type": "object",
      "properties": {
        "servers": {
          "description": "Named MCP server configurations.",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/McpServer"
          },
          "default": {}
        }
      }
    },
    "McpServer": {
      "description": "An MCP server configuration entry.",
      "type": "object",
      "properties": {
        "command": {
          "description": "Command and arguments for stdio transport.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "headers": {
          "description": "HTTP headers for http/sse transports.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "scope": {
          "description": "Scope: global or project.",
          "$ref": "#/$defs/ConfigScope",
          "default": "global"
        },
        "transport": {
          "description": "Transport type: stdio, http, or sse.",
          "$ref": "#/$defs/McpTransport",
          "default": "stdio"
        },
        "url": {
          "description": "URL for http/sse transports.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "McpTransport": {
      "description": "Transport type for MCP server communication.",
      "oneOf": [
        {
          "description": "Stdio-based MCP server (default).",
          "type": "string",
          "const": "stdio"
        },
        {
          "description": "HTTP-based MCP server.",
          "type": "string",
          "const": "http"
        },
        {
          "description": "Server-Sent Events transport.",
          "type": "string",
          "const": "sse"
        }
      ]
    },
    "ModelProvider": {
      "description": "A provider's configuration entry.",
      "type": "object",
      "properties": {
        "api_key": {
          "type": "string",
          "default": ""
        },
        "base_url": {
          "type": "string"
        },
        "models": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "type": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "base_url"
      ]
    },
    "ModelsSection": {
      "description": "Models configuration section.",
      "type": "object",
      "properties": {
        "default": {
          "description": "The default model to use when no model is specified.",
          "type": [
            "string",
            "null"
          ]
        },
        "scoped": {
          "description": "Scoped models list (for model selector UI).",
          "type": [
            "array",
            "null"
          ],
          "default": null,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PermissionAction": {
      "description": "Permission action result.\n\nThis is the canonical enum for permission decisions throughout the codebase.\nThe protocol's `ApprovalDecision` (Allow/Deny only) is converted to this type\nat the protocol/core boundary via `From<crate::proto::op::ApprovalDecision>`.",
      "type": "string",
      "enum": [
        "allow",
        "ask",
        "deny"
      ]
    },
    "PermissionMode": {
      "description": "Global permission mode.",
      "oneOf": [
        {
          "description": "Apply rules; ask when no rule matches.",
          "type": "string",
          "const": "default"
        },
        {
          "description": "Auto-accept file edits; ask for shell commands.",
          "type": "string",
          "const": "accept_edits"
        },
        {
          "description": "Auto-approve safe operations; ask for risky ones.",
          "type": "string",
          "const": "auto"
        },
        {
          "description": "Approve unless a deny rule matches.",
          "type": "string",
          "const": "dont_ask"
        },
        {
          "description": "Approve everything (dangerous).",
          "type": "string",
          "const": "bypass_permissions"
        },
        {
          "description": "Block write tools until a plan is approved.",
          "type": "string",
          "const": "plan"
        }
      ]
    },
    "PermissionRule": {
      "description": "A single permission rule with glob patterns and scope.",
      "type": "object",
      "properties": {
        "action": {
          "description": "Action when rule matches: \"allow\", \"ask\", or \"deny\".",
          "$ref": "#/$defs/PermissionAction"
        },
        "path": {
          "description": "Optional glob pattern for file paths.",
          "type": [
            "string",
            "null"
          ]
        },
        "pattern": {
          "description": "Optional glob pattern for shell command arguments.",
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "description": "Scope of this rule: user, project, or session.\nHigher scopes override lower scopes (session > project > user).",
          "$ref": "#/$defs/PermissionScope",
          "default": "user"
        },
        "tool": {
          "description": "Glob pattern for tool name, e.g. \"bash\", \"read_*\", \"*\".",
          "type": "string"
        }
      },
      "required": [
        "action",
        "tool"
      ]
    },
    "PermissionScope": {
      "description": "Scope of a permission rule.",
      "oneOf": [
        {
          "description": "User-level rules from ~/.runie/config.toml",
          "type": "string",
          "const": "user"
        },
        {
          "description": "Project-level rules from .runie/config.toml or AGENTS.md",
          "type": "string",
          "const": "project"
        },
        {
          "description": "Session-level rules from CLI flags",
          "type": "string",
          "const": "session"
        }
      ]
    },
    "PermissionsSection": {
      "description": "Permissions configuration section.",
      "type": "object",
      "properties": {
        "mode": {
          "description": "Permission mode: default, acceptEdits, auto, dontAsk, bypassPermissions, plan.",
          "$ref": "#/$defs/PermissionMode",
          "default": "default"
        },
        "rules": {
          "description": "Explicit permission rules.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/PermissionRule"
          }
        }
      }
    },
    "PromptsSection": {
      "description": "Prompts configuration section.",
      "type": "object",
      "properties": {
        "custom": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "default": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "TelemetrySection": {
      "description": "Telemetry configuration section.",
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "ThinkingLevel": {
      "description": "Thinking level for reasoning-intensive tasks.",
      "type": "string",
      "enum": [
        "Off",
        "Low",
        "Medium",
        "High"
      ]
    },
    "TruncationSection": {
      "description": "Truncation limits for tool output.",
      "type": "object",
      "properties": {
        "max_bytes": {
          "type": "integer",
          "format": "uint",
          "default": 51200,
          "minimum": 0
        },
        "max_lines": {
          "type": "integer",
          "format": "uint",
          "default": 2000,
          "minimum": 0
        }
      }
    },
    "UiSection": {
      "description": "UI configuration section.",
      "type": "object",
      "properties": {
        "vim_mode": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
#!/usr/bin/env bash
# `runie-dspec-watch <spec.dspec.json> [--diff <grok.txt>]`
# Polls the spec file every 200ms; re-renders on mtime change.
# Iteration cycle: ~10ms per change (no cargo build).

set -euo pipefail

SPEC="${1:?usage: runie-dspec-watch <spec.dspec.json> [--diff grok.txt]}"
shift
[ -f "$SPEC" ] || { echo "spec not found: $SPEC" >&2; exit 2; }

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

# Resolve binary
BIN="$REPO_ROOT/target/debug/runie-dspec"
if [ ! -x "$BIN" ]; then
  echo "building runie-dspec..." >&2
  PATH="$HOME/.cargo/bin:$PATH" RUNIE_SKIP_BUILD_CHECKS=1 cargo build -p runie-tui --bin runie-dspec >/dev/null 2>&1
fi

LAST_MTIME=0
while true; do
  MTIME=$(stat -f '%m' "$SPEC" 2>/dev/null || stat -c '%Y' "$SPEC" 2>/dev/null || echo 0)
  if [ "$MTIME" != "$LAST_MTIME" ]; then
    LAST_MTIME=$MTIME
    clear
    printf '\033[1;36m── %s ──\033[0m\n' "$(date +%H:%M:%S.%N | cut -c1-12)"
    "$BIN" "$SPEC" "$@" 2>&1 || true
  fi
  sleep 0.2
done
